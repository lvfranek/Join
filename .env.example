# ===== Database provider switch =====
# Possible values: "supabase" | "mariadb"
DB_PROVIDER=supabase

# ===== Frontend API base URL (used when DB_PROVIDER=mariadb) =====
# Points to the Express backend that talks to MariaDB.
API_URL=http://localhost:3000/api

# ===== Supabase (used when DB_PROVIDER=supabase) =====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Server-only, do NOT ship to the browser:
SUPABASE_SERVICE_KEY=

# ===== MariaDB (used when DB_PROVIDER=mariadb) =====
# These vars are consumed by the Node/Express backend in /server, never the browser.
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=demo_join
MARIADB_PASSWORD=changeme
MARIADB_DATABASE=demo_join
MARIADB_CONNECTION_LIMIT=10

# JWT secret used by the Express backend to sign auth tokens
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Backend HTTP port
SERVER_PORT=3000
# Allowed CORS origin for the Angular dev server
CORS_ORIGIN=http://localhost:4200
